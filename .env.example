# ParamX Hunter - Environment Configuration
# Copy to .env and fill in production values

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=ParamX Hunter
VERSION=1.0.0
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://paramx:paramx@localhost:5432/paramx
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ── JWT / Security ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-USE-256-BIT-RANDOM-KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Crawling ─────────────────────────────────────────────────────────────────
DEFAULT_CONCURRENCY=50
MAX_SCAN_CONCURRENCY=200
MAX_REQUESTS_PER_SCAN=500000

# ── Auth ─────────────────────────────────────────────────────────────────────
REQUIRE_EMAIL_VERIFICATION=false

# ── Reporting ────────────────────────────────────────────────────────────────
REPORTS_DIR=/tmp/paramx_reports
LOGO_PATH=
